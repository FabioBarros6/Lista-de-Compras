{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ShoppingList": {
      "title": "Shopping List",
      "description": "A list of items to buy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerEmail": { "type": "string", "description": "Email of the list owner" },
        "sharedWith": {
          "type": "object",
          "description": "Map of user UIDs to permission levels (viewer, editor)"
        },
        "name": { "type": "string" },
        "date": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "archived"],
          "description": "Current status of the list"
        },
        "items": {
          "type": "array",
          "items": { "$ref": "ShoppingItem" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "status"]
    },
    "ShoppingItem": {
      "title": "Shopping Item",
      "description": "An item in a shopping list",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" }
      },
      "required": ["id", "name", "quantity", "unit"]
    },
    "ListLog": {
      "title": "List Log",
      "description": "A log of activity on a shopping list",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/lists/{listId}": {
      "schema": "ShoppingList",
      "description": "Shopping lists"
    },
    "/lists/{listId}/logs/{logId}": {
      "schema": "ListLog",
      "description": "Activity logs for a shopping list"
    }
  }
}
